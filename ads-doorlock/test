<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jasa Pasang Smart Door Lock Ahli & Bergaransi</title>
    <style>
        /* Reset & Base Styles */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Arial', sans-serif;
        }
        body {
            background-color: #f8f9fa;
            color: #333;
            line-height: 1.6;
        }
        .container {
            width: 90%;
            max-width: 1100px;
            margin: 0 auto;
            padding: 40px 0;
        }

        /* Hero Section */
        .hero {
            background: linear-gradient(135deg, #102a43 0%, #243b53 100%);
            color: #fff;
            text-align: center;
            padding: 80px 20px;
        }
        .hero h1 {
            font-size: 2.5rem;
            font-weight: bold;
            margin-bottom: 20px;
            line-height: 1.2;
        }
        .hero p {
            font-size: 1.2rem;
            margin-bottom: 30px;
            color: #bcccdc;
        }
        .btn-cta {
            display: inline-block;
            background-color: #25d366; /* Warna WhatsApp */
            color: white;
            padding: 16px 32px;
            font-size: 1.2rem;
            font-weight: bold;
            text-decoration: none;
            border-radius: 50px;
            box-shadow: 0 4px 15px rgba(37, 211, 102, 0.4);
            transition: transform 0.2s, background-color 0.2s;
        }
        .btn-cta:hover {
            transform: scale(1.05);
            background-color: #20ba5a;
        }

        /* Problem Section */
        .problems {
            background-color: #fff;
            text-align: center;
        }
        .section-title {
            font-size: 2rem;
            margin-bottom: 30px;
            position: relative;
        }
        .section-title::after {
            content: '';
            display: block;
            width: 60px;
            height: 4px;
            background-color: #486581;
            margin: 10px auto 0;
            border-radius: 2px;
        }
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-top: 30px;
        }
        .card {
            background: #f0f4f8;
            padding: 25px;
            border-radius: 8px;
            border-left: 5px solid #486581;
            text-align: left;
        }
        .card h3 {
            margin-bottom: 10px;
            color: #102a43;
        }

        /* Services & Table Section */
        .services {
            background-color: #f0f4f8;
        }
        .table-container {
            overflow-x: auto;
            margin-top: 20px;
            background: #fff;
            padding: 15px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }
        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }
        th, td {
            padding: 15px;
            border-bottom: 1px solid #e2e8f0;
        }
        th {
            background-color: #102a43;
            color: white;
            font-weight: bold;
        }
        tr:nth-child(even) {
            background-color: #f8fafc;
        }

        /* FAQ Section */
        .faq {
            background-color: #fff;
        }
        .faq-item {
            margin-bottom: 20px;
            padding-bottom: 20px;
            border-bottom: 1px solid #e2e8f0;
        }
        .faq-item h3 {
            color: #102a43;
            margin-bottom: 8px;
            font-size: 1.1rem;
        }

        /* Floating WhatsApp Button */
        .floating-wa {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background-color: #25d366;
            color: white;
            width: 60px;
            height: 60px;
            border-radius: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
            font-weight: bold;
            font-size: 24px;
            z-index: 1000;
            transition: transform 0.2s;
        }
        .floating-wa:hover {
            transform: scale(1.1);
        }

        /* Footer / Closing CTA */
        .footer-cta {
            background: #102a43;
            color: white;
            text-align: center;
            padding: 60px 20px;
        }
        .footer-cta h2 {
            font-size: 2rem;
            margin-bottom: 15px;
        }
        .footer-cta p {
            margin-bottom: 25px;
            color: #bcccdc;
        }

        /* Responsive Breakpoints */
        @media (max-width: 768px) {
            .hero h1 { font-size: 2rem; }
            .section-title { font-size: 1.6rem; }
            th, td { padding: 10px; font-size: 0.9rem; }
        }
    </style>
</head>
<body>

